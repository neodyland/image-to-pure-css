{
  "name": "js",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build:html": "html-minifier ./dist/index.html --collapse-whitespace --remove-comments --minify-css true --minify-js true -o ./dist/index.html",
    "build:js": "esbuild --bundle --loader:.wasm=binary --platform=browser --format=esm --minify ./lib.ts --outfile=./pkg/client.js",
    "build:vite": "vite build",
    "build": "run-s build:js build:vite build:html"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "esbuild": "^0.28.1",
    "html-minifier": "^4.0.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
